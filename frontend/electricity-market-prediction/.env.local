# ========================
# Frontend Development Configuration
# ========================

# API Port for local development (npm run dev outside Docker).
# Next.js rewrites /api/* → http://localhost:PORT/api/* server-side,
# so the browser never makes a cross-origin request.
NEXT_PUBLIC_API_PORT=6873

# Force API calls to use the local Next.js origin (/api) so rewrites kick in.
NEXT_PUBLIC_API_URL=http://localhost:3000/api
