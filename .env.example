
# ========================
# Configuration
# ========================

PROJECT_NAME=jpex-dashboard
PROJECT_PORT=6873
DEBUG=True
SECRET_KEY=my-secret-key

# ========================
# Third-party Login (OAuth 2.0 / OIDC)
# ========================
# Each provider is enabled only when both CLIENT_ID and CLIENT_SECRET are set.
# Register an OAuth app at the provider and set the redirect URI to:
#   {your-site}/api/auth/oauth/google/callback
#   {your-site}/api/auth/oauth/microsoft/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Use "common" for multi-tenant + personal accounts; or a specific tenant GUID.
MICROSOFT_TENANT=common
# Optional override for the post-callback browser redirect target. Leave
# empty for same-origin deployments — the frontend bridge URL is a relative
# path and the browser resolves the scheme/host. Set this only when the
# frontend and backend live on different origins.
#
# (The OAuth provider's redirect_uri is derived automatically from the
# incoming request via request.url_for + ProxyHeadersMiddleware — no env
# override exists or is needed.)
FRONTEND_BASE_URL=

# ========================
# Account Management Notes (read on first deploy)
# ========================
# - EXISTING DATABASES MUST RUN: alembic upgrade head
#   The startup `create_all` only creates missing tables and will NOT alter
#   the existing `users` table (nullable hashed_password + is_pending).
# - The "allow public registration" and "require admin approval" toggles
#   live in the `app_settings` table (singleton row id=1) and are changed
#   from the in-app admin page, NOT here.

# ========================
# Elasticsearch Configuration
# ========================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Elasticsearch Index Names (Optional - defaults match data-mapping.md)
ES_INDEX_PREDICTION=prediction
ES_INDEX_JEPX=jepx_spot_area_price
ES_INDEX_JEPX_SYSTEM=jepx_spot_system
ES_INDEX_IMBALANCE=imbalance
ES_INDEX_HJKS=hjks_outage
ES_INDEX_INTERCONNECTION=occto_inter
ES_INDEX_INTRADAY=jepx_intraday
ES_INDEX_EARTHQUAKE=jma_earthquake_actual
ES_INDEX_OCCTO_AREA=occto_area
ES_INDEX_OCCTO_INTER=occto_inter
ES_INDEX_OCCTO_EVENT=occto_event
ES_INDEX_TDGC=tdgc
ES_INDEX_WEATHER_ACTUAL_HOURLY=weather_actual_hourly
ES_INDEX_WEATHER_ACTUAL_DAILY=weather_actual_daily
ES_INDEX_WEATHER_FORECAST_HOURLY=weather_forecast_hourly
ES_INDEX_WEATHER_FORECAST_DAILY=weather_forecast_daily
ES_INDEX_BATTERY_DATA=battery_data

# ========================
# Optimization Configuration
# ========================
P_MAX_CH=2000
P_MAX_DIS=2000
E_CAP=8000
SOC_MIN_PCT=0.0
SOC_MAX_PCT=1.0
COST_CYCLE=0.0
MIN_BID=0.0
